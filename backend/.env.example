# Biến môi trường Back-end (đặt trong Dashboard của Render/Koyeb, KHÔNG commit giá trị thật)

# Cổng — Render/Koyeb tự cấp; để mặc định khi chạy Docker local
PORT=8888

# Chuỗi kết nối PostgreSQL (Neon/Supabase) — nhớ sslmode=require
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Khóa ký JWT — chuỗi ngẫu nhiên mạnh (vd: openssl rand -base64 48)
JWT_SECRET=thay-bang-chuoi-bi-mat-ngau-nhien

# Domain Front-end được phép gọi API (phân tách bằng dấu phẩy)
FRONTEND_ORIGIN=https://moca-erp.vercel.app
